{
  "name": "measuretent",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:api": "pnpm --filter @measurtent/api dev",
    "dev:web": "pnpm --filter @measurtent/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.20.6",
